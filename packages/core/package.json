{
  "name": "@bbangto-ui/core",
  "version": "0.1.0",
  "description": "Core React components for bbangto-ui",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@bbangto-ui/theme-light": "workspace:*",
    "@bbangto-ui/tokens": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "cheerio": "^1.2.0",
    "fs-extra": "^11.3.5",
    "lucide-static": "^1.21.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "sideEffects": false
}
