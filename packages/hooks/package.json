{
  "name": "@centurio1987/bbangto-ui-hooks",
  "version": "0.3.0",
  "description": "Headless React hooks for bbangto-ui",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.2.0",
    "jsdom": "^25.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/centurio1987/bbangto-ui.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
