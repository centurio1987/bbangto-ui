{
  "name": "@centurio1987/bbangto-ui-foundations",
  "version": "1.0.0",
  "description": "Foundation catalog for bbangto-ui — amber + 74 brand presets (base light/dark/high-contrast live in core)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./catalog": "./src/catalog.json"
  },
  "files": [
    "dist",
    "src/catalog.json"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@centurio1987/bbangto-ui-tokens": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/centurio1987/bbangto-ui.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
