{
  "name": "@centurio1987/themes-external",
  "version": "0.1.0",
  "description": "External brand themes inspired by getdesign.md / awesome-design-md",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./catalog": "./src/catalog.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@centurio1987/tokens": "workspace:*",
    "@centurio1987/theme-light": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/centurio1987/bbangto-ui.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
