{
  "name": "bbangto-ui",
  "private": true,
  "version": "0.0.0",
  "description": "Design System Store - Themeable component library",
  "scripts": {
    "dev": "pnpm --filter storybook storybook",
    "build": "pnpm -r --filter=!storybook run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm --filter storybook test",
    "test:unit": "pnpm -r --filter=!storybook run test",
    "storybook": "pnpm --filter storybook storybook",
    "build-storybook": "pnpm --filter storybook build-storybook",
    "version-packages": "changeset version && node scripts/postversion-fix.mjs",
    "release": "pnpm -r publish --no-git-checks",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
